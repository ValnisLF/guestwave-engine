// schema.prisma – Prisma 6 Schema para GuestWave Engine
// Ejecuta `npx prisma db push` tras colocar tu DATABASE_URL en .env.local
// Los enums se exportan automáticamente desde @prisma/client en Server Actions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/////////////////////////////////////////
// Enums exportables para Server Actions
// Importa: import { BookingStatus, BlockedSource, UserRole } from "@prisma/client"
/////////////////////////////////////////

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum BlockedSource {
  ICAL
  MANUAL
  BOOKING
}

enum UserRole {
  ADMIN
  OWNER
}

enum MembershipRole {
  OWNER
}

enum PaymentMode {
  FULL
  DEPOSIT
}

/////////////////////////////////////////
// models
/////////////////////////////////////////

model Property {
  id                String        @id @default(uuid()) @db.Uuid
  name              String
  slug              String        @unique
  description       String?
  imageUrls         String[]      @default([])
  amenities         Json
  basePrice         Decimal       @db.Decimal(12,2)
  cleaningFee       Decimal       @db.Decimal(12,2)    // nueva prima
  minimumStay       Int           @default(1)
  depositPercentage Int
  bookingPrefix     String        @default("EF") // @zod.max(3)
  icalUrlIn         String?       // URL iCal externa
  autoSyncEnabled   Boolean       @default(false)
  autoSyncIntervalMinutes Int     @default(30)
  autoSyncLastRunAt DateTime?
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPassword      String?
  smtpFromEmail     String?
  icalCalendars     PropertyIcalCalendar[]
  memberships       PropertyMembership[]
  invites           PropertyInvite[]
  seasonRates       SeasonRate[]
  bookings          Booking[]
  refundAudits      BookingRefundAudit[]
  blockedDates      BlockedDate[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model PropertyIcalCalendar {
  id            String      @id @default(uuid()) @db.Uuid
  property      Property    @relation(fields: [propertyId], references: [id])
  propertyId    String      @db.Uuid
  name          String
  icalUrl       String
  lastSyncedAt  DateTime?
  lastSyncSuccessAt DateTime?
  blockedDates  BlockedDate[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([propertyId])
}

model SeasonRate {
  id              String   @id @default(uuid()) @db.Uuid
  property        Property @relation(fields: [propertyId], references: [id])
  propertyId      String   @db.Uuid
  startDate       DateTime
  endDate         DateTime
  priceMultiplier Decimal  @db.Decimal(5,4)
  fixedPrice      Decimal? @db.Decimal(12,2)
  paymentMode     PaymentMode?
  depositPercentage Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  bookingCode     String        @unique
  property        Property      @relation(fields: [propertyId], references: [id])
  propertyId      String        @db.Uuid
  status          BookingStatus
  checkIn         DateTime
  checkOut        DateTime
  totalPrice      Decimal       @db.Decimal(12,2)
  depositAmount   Decimal       @db.Decimal(12,2)
  guestEmail      String?
  guestToken      String        @default(uuid())
  stripeSessionId String        @unique
  blockedDates    BlockedDate[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([propertyId])
}

model BlockedDate {
  id          String        @id @default(uuid()) @db.Uuid
  property    Property      @relation(fields: [propertyId], references: [id])
  propertyId  String        @db.Uuid
  startDate   DateTime
  endDate     DateTime
  source      BlockedSource
  createdBy   User?         @relation("ManualBlockCreator", fields: [createdByUserId], references: [id])
  createdByUserId String?   @db.Uuid
  icalCalendar   PropertyIcalCalendar? @relation(fields: [icalCalendarId], references: [id])
  icalCalendarId String?      @db.Uuid
  booking     Booking?      @relation(fields: [bookingId], references: [id])
  bookingId   String?       @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([propertyId])
  @@index([createdByUserId])
  @@index([icalCalendarId])
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  passwordHash String?
  role      UserRole @default(ADMIN)
  manualBlockedDates BlockedDate[] @relation("ManualBlockCreator")
  bookingRefundAudits BookingRefundAudit[]
  memberships PropertyMembership[]
  sessions  AdminSession[]
  invitesSent PropertyInvite[] @relation("InviteSender")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookingRefundAudit {
  id                String   @id @default(uuid()) @db.Uuid
  bookingId         String   @db.Uuid
  property          Property @relation(fields: [propertyId], references: [id])
  propertyId        String   @db.Uuid
  performedBy       User     @relation(fields: [performedByUserId], references: [id])
  performedByUserId String   @db.Uuid
  guestEmail        String?
  amount            Decimal  @db.Decimal(12,2)
  refundId          String
  refundStatus      String
  createdAt         DateTime @default(now())

  @@index([propertyId])
  @@index([performedByUserId])
  @@index([bookingId])
}

model AdminSession {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PropertyMembership {
  id          String         @id @default(uuid()) @db.Uuid
  user        User           @relation(fields: [userId], references: [id])
  userId      String         @db.Uuid
  property    Property       @relation(fields: [propertyId], references: [id])
  propertyId  String         @db.Uuid
  role        MembershipRole @default(OWNER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model PropertyInvite {
  id              String         @id @default(uuid()) @db.Uuid
  token           String         @unique
  email           String
  property        Property       @relation(fields: [propertyId], references: [id])
  propertyId      String         @db.Uuid
  role            MembershipRole @default(OWNER)
  invitedBy       User           @relation("InviteSender", fields: [invitedByUserId], references: [id])
  invitedByUserId String         @db.Uuid
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime       @default(now())

  @@index([propertyId])
  @@index([email])
}